# Copy to .env and fill in. NEVER commit .env.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub (Personal Access Token, repo:read scope; needed for private repos) ---
GITHUB_TOKEN=ghp_...

# --- X / Twitter API v2 (OAuth 2.0 user-context tokens) ---
# Mint these once with:  python scripts/x_oauth.py --redirect-uri "https://127.0.0.1/callback"
# Scopes must include tweet.write + offline.access (the refresh token enables
# auto-refresh; without it the ~2h access token expires and posting stops).
# Never use password login or browser automation (both are bannable).
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=
# Must exactly match a Callback URI on your X app (only used by scripts/x_oauth.py).
X_REDIRECT_URI=https://127.0.0.1/callback

# --- Telegram (Phase 2 approval UI) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- Runtime ---
# Path to the SQLite state file.
XGROWTH_DB_PATH=data/xgrowth.db
# Path to the YAML config (see config.example.yaml).
XGROWTH_CONFIG_PATH=config.yaml
# Set to 1 to disable all real network writes (X posts). Useful for first runs.
XGROWTH_DRY_RUN=1
# FastAPI admin bind. Keep 127.0.0.1 unless you must reach the admin API from the
# host — the admin endpoints have no auth. In Docker, set 0.0.0.0 only if you also
# publish port 8080 (see docker-compose.yml).
XGROWTH_HOST=127.0.0.1
XGROWTH_PORT=8080

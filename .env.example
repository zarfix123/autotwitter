# Copy to .env and fill in. NEVER commit .env.

# --- Anthropic (Claude) ---
ANTHROPIC_API_KEY=sk-ant-...

# --- GitHub (Personal Access Token, repo:read scope; needed for private repos) ---
GITHUB_TOKEN=ghp_...

# --- X / Twitter API v2 (OAuth 2.0 user-context tokens) ---
# Obtain via the OAuth 2.0 Authorization Code w/ PKCE flow. Never use password login.
X_CLIENT_ID=
X_CLIENT_SECRET=
X_ACCESS_TOKEN=
X_REFRESH_TOKEN=

# --- Telegram (Phase 2 approval UI) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USER_ID=

# --- Runtime ---
# Path to the SQLite state file.
XGROWTH_DB_PATH=data/xgrowth.db
# Path to the YAML config (see config.example.yaml).
XGROWTH_CONFIG_PATH=config.yaml
# Set to 1 to disable all real network writes (X posts). Useful for first runs.
XGROWTH_DRY_RUN=1
# FastAPI admin bind.
XGROWTH_HOST=127.0.0.1
XGROWTH_PORT=8080
